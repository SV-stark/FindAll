/* Define to 1 if you have the `feenableexcept' function. */
#cmakedefine HAVE_FEENABLEEXCEPT 1


/* Version number */
#cmakedefine PACKAGE_VERSION "5.5.2"
#cmakedefine GRAPHICS_DISABLED ON
#cmakedefine FAST_FLOAT ON
#cmakedefine DISABLED_LEGACY_ENGINE OFF
#cmakedefine HAVE_TIFFIO_H OFF
#cmakedefine HAVE_NEON FALSE
#cmakedefine HAVE_LIBARCHIVE OFF
#cmakedefine HAVE_LIBCURL OFF

#cmakedefine TESSDATA_PREFIX "C:/tess"
